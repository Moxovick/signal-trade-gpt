# --- Database (Postgres) ---
# DATABASE_URL: pooled connection (use Supabase Connection Pooler URI on port 6543).
# DIRECT_URL:   direct connection used by `prisma migrate` / `prisma db push`
#               (use Supabase Direct Connection URI on port 5432).
# Locally, both can point to the same Postgres.
DATABASE_URL="postgresql://postgres:password@localhost:5432/signal_trade_gpt?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/signal_trade_gpt?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:password@localhost:5432/signal_trade_gpt_shadow?schema=public"

# --- NextAuth ---
AUTH_SECRET="change-me-to-a-random-32-char-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Telegram (public) ---
# Bot username for the Telegram Login Widget.
NEXT_PUBLIC_TELEGRAM_LOGIN_BOT="my_bot_username"
NEXT_PUBLIC_BOT_USERNAME="my_bot_username"
NEXT_PUBLIC_BOT_URL="https://t.me/my_bot_username"

# --- Telegram (server) ---
# Bot token used to verify Telegram Login Widget signatures.
TELEGRAM_LOGIN_BOT_TOKEN=""

# --- PocketOption postback ---
# Shared secret signing the X-Signature header on incoming postbacks.
POCKETOPTION_POSTBACK_SECRET=""

# --- Bot sync ---
# Shared secret the bot uses on the X-Bot-Secret header when polling
# GET /api/bot/sync. Must match BOT_SYNC_SECRET in bot/.env.
BOT_SYNC_SECRET=""

# --- Optional ---
# Chipa API key for real candle data on the live chart. Leave blank to use
# deterministic synthetic candles (good enough for dev/staging).
CHIPA_API_KEY=""
