# Telegram Bot Configuration
BOT_TOKEN=PLACEHOLDER_GET_FROM_BOTFATHER
CHANNEL_ID=-1001234567890

# Signal Generation
SIGNAL_INTERVAL_MIN=5
SIGNAL_INTERVAL_MAX=15
WORKING_HOURS_START=8
WORKING_HOURS_END=22

# Database
DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# PocketOption referral link (used in inline button + signal links).
# Place your aff URL with {click_id} placeholder if you want to attribute users.
POCKET_OPTION_URL=https://pocketoption.com

# Telegram Mini App entrypoint. Empty disables Mini App buttons.
WEBAPP_URL=https://signal-trade-gpt.vercel.app/tma

# Web platform base URL — when set together with BOT_SYNC_SECRET, the bot
# polls /api/bot/sync every 60s, mirrors tier+deposit, and pushes a
# "Tier unlocked" message to the user when their tier increases on PocketOption.
PLATFORM_API_URL=
BOT_SYNC_SECRET=

# Comma-separated telegram_ids that can run /admin commands inside the bot
# (broadcast, ban, set_tier, etc). Leave empty to disable.
ADMIN_IDS=

# PocketOption Affiliate API — direct trader-info lookup.
# Token: from your PocketOption affiliate dashboard (Settings → API).
# Partner ID: your numeric partner id.
# Both must be set to enable verification on /link.
POCKETOPTION_API_TOKEN=
POCKETOPTION_PARTNER_ID=

# Logging
LOG_LEVEL=INFO
