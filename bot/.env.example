# Telegram Bot Configuration
BOT_TOKEN=PLACEHOLDER_GET_FROM_BOTFATHER
CHANNEL_ID=-1001234567890

# Signal Generation
SIGNAL_INTERVAL_MIN=5
SIGNAL_INTERVAL_MAX=15
WORKING_HOURS_START=8
WORKING_HOURS_END=22

# Database
DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# PocketOption referral link (used in inline button + signal links).
# Place your aff URL with {click_id} placeholder if you want to attribute users.
POCKET_OPTION_URL=https://pocketoption.com

# Optional: web platform base URL — when set, the bot will sync tier with
# the web platform's REST API on /tier and /signal commands.
PLATFORM_API_URL=

# Logging
LOG_LEVEL=INFO
